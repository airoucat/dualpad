+++ b/src/haptics/EventWindowScorer.cpp
@@ -0,0 +1,478 @@
+﻿#include "pch.h"
+#include "haptics/EventWindowScorer.h"
+#include "haptics/HapticsConfig.h"
+#include "haptics/VoiceManager.h"
+#include "haptics/EventQueue.h"
+#include <SKSE/SKSE.h>
+#include <algorithm>
+#include <cmath>
+
+namespace logger = SKSE::log;
+
+namespace dualpad::haptics
+{
+    EventWindowScorer& EventWindowScorer::GetSingleton()
+    {
+        static EventWindowScorer instance;
+        return instance;
+    }
+
+    void EventWindowScorer::Initialize()
+    {
+        if (_initialized) {
+            logger::warn("[Haptics][Scorer] Already initialized");
+            return;
+        }
+
+        logger::info("[Haptics][Scorer] Initializing...");
+
+        _activeWindows.reserve(32);
+        _initialized = true;
+
+        logger::info("[Haptics][Scorer] Initialized");
+    }
+
+    void EventWindowScorer::Shutdown()
+    {
+        if (!_initialized) {
+            return;
+        }
+
+        logger::info("[Haptics][Scorer] Shutting down...");
+
+        {
+            std::scoped_lock lock(_mutex);
+            _activeWindows.clear();
+        }
+
+        _initialized = false;
+
+        logger::info("[Haptics][Scorer] Shutdown complete");
+    }
+
+    void EventWindowScorer::AddEvent(const EventMsg& event)
+    {
+        if (!_initialized) {
+            return;
+        }
+
+        auto& config = HapticsConfig::GetSingleton();
+
+        EventWindow window;
+        window.event = event;
+
+        auto eventTime = FromQPC(event.qpc);
+        window.windowStart = eventTime - std::chrono::milliseconds(config.windowPreMs);
+        window.windowEnd = eventTime + std::chrono::milliseconds(config.windowPostMs);
+        window.resolved = false;
+
+        {
+            std::scoped_lock lock(_mutex);
+            _activeWindows.push_back(window);
+        }
+
+        _totalEvents.fetch_add(1, std::memory_order_relaxed);
+
+        logger::trace("[Haptics][Scorer] Event added: type={} qpc={} window=[{}, {}]",
+            ToString(event.type), event.qpc,
+            ToQPC(window.windowStart), ToQPC(window.windowEnd));
+    }
+
+    void EventWindowScorer::AddAudioFeature(const AudioFeatureMsg& feature)
+    {
+        if (!_initialized) {
+            return;
+        }
+
+        auto featureTime = FromQPC(feature.qpcStart);
+
+        std::scoped_lock lock(_mutex);
+
+        // 尝试匹配到所有活跃窗口
+        for (auto& window : _activeWindows) {
+            if (window.resolved) {
+                continue;
+            }
+
+            // 检查是否在窗口内
+            if (featureTime >= window.windowStart && featureTime <= window.windowEnd) {
+                window.candidates.push_back(feature);
+
+                logger::trace("[Haptics][Scorer] Feature matched to window: event={} voiceId={} rms={:.3f}",
+                    ToString(window.event.type), feature.voiceId, feature.rms);
+            }
+        }
+    }
+
+    std::vector<HapticSourceMsg> EventWindowScorer::Update()
+    {
+        if (!_initialized) {
+            return {};
+        }
+
+        // 从 EventQueue 拉取新事件
+        auto newEvents = EventQueue::GetSingleton().DrainAll();
+        if (!newEvents.empty()) {
+            logger::info("[Haptics][Scorer] Pulled {} events from queue", newEvents.size());
+        }
+
+        for (const auto& event : newEvents) {
+            AddEvent(event);
+            logger::info("[Haptics][Scorer] Event added: type={} intensity={:.2f}",
+                ToString(event.type), event.intensity);
+        }
+
+        AudioFeatureMsg feats[256];
+        const auto n = VoiceManager::GetSingleton().PopAudioFeatures(feats, std::size(feats));
+        for (size_t i = 0; i < n; ++i) {
+            AddAudioFeature(feats[i]);
+        }
+        if (n > 0) {
+            logger::info("[Haptics][Scorer] Pulled {} audio features", n);
+        }
+
+        std::vector<HapticSourceMsg> results;
+
+        auto& config = HapticsConfig::GetSingleton();
+        auto now = Now();
+
+        std::scoped_lock lock(_mutex);
+
+        // 遍历所有窗口
+        for (auto it = _activeWindows.begin(); it != _activeWindows.end(); ) {
+            auto& window = *it;
+
+            // 检查窗口是否已超时
+            if (now > window.windowEnd) {
+                // 窗口关闭，生成最佳匹配
+                if (!window.candidates.empty()) {
+                    float bestScore = 0.0f;
+                    AudioFeatureMsg bestFeature;
+                    bool found = false;
+
+                    for (const auto& candidate : window.candidates) {
+                        float score = ScoreFeature(window.event, candidate, window.event.qpc);
+
+                        if (score > bestScore) {
+                            bestScore = score;
+                            bestFeature = candidate;
+                            found = true;
+                        }
+                    }
+
+                    if (found && bestScore >= config.minConfidence) {
+                        window.bestMatch = bestFeature;
+                        window.bestScore = bestScore;
+                        window.hasMatch = true;
+
+                        _totalMatched.fetch_add(1, std::memory_order_relaxed);
+
+                        logger::trace("[Haptics][Scorer] Window resolved: event={} score={:.3f} voiceId={}",
+                            ToString(window.event.type), bestScore, bestFeature.voiceId);
+                    }
+                    else {
+                        _totalUnmatched.fetch_add(1, std::memory_order_relaxed);
+
+                        logger::trace("[Haptics][Scorer] Window unmatched: event={} candidates={} bestScore={:.3f}",
+                            ToString(window.event.type), window.candidates.size(), bestScore);
+                    }
+                }
+                else {
+                    _totalUnmatched.fetch_add(1, std::memory_order_relaxed);
+
+                    logger::info("[Haptics][Scorer] Window closed without audio: event={}",
+                        ToString(window.event.type));
+                }
+
+                // 生成触觉源消息（可配置开关）
+                const bool isAudioDriven = (config.hapticsMode == HapticsConfig::HapticsMode::AudioDriven);
+
+                if (window.hasMatch) {
+                    // 有音频匹配：先加音频调制
+                    auto audioMsg = CreateAudioModulation(window.event, window.bestMatch, window.bestScore);
+                    results.push_back(audioMsg);
+
+                    logger::info("[Haptics][Scorer] Created audio modulation: type={} score={:.2f} L={:.2f} R={:.2f}",
+                        ToString(window.event.type), window.bestScore, audioMsg.left, audioMsg.right);
+
+                    // AudioDriven 下是否还叠加 base，由开关决定
+                    bool allowBaseTogether = true;
+                    if (isAudioDriven && config.audioDrivenPreferAudioOnly) {
+                        allowBaseTogether = false;
+                    }
+
+                    if (allowBaseTogether && config.enableBasePulse) {
+                        auto baseMsg = CreateBaseEventPulse(window.event);
+                        results.push_back(baseMsg);
+
+                        logger::info("[Haptics][Scorer] Created base pulse (with match): type={} L={:.2f} R={:.2f}",
+                            ToString(window.event.type), baseMsg.left, baseMsg.right);
+                    }
+                }
+                else {
+                    // 无音频匹配：是否允许 base 兜底
+                    if (config.enableBasePulse && config.fallbackBaseWhenNoMatch) {
+                        auto baseMsg = CreateBaseEventPulse(window.event);
+                        results.push_back(baseMsg);
+
+                        logger::info("[Haptics][Scorer] Created fallback base pulse: type={} L={:.2f} R={:.2f}",
+                            ToString(window.event.type), baseMsg.left, baseMsg.right);
+                    }
+                }
+
+                // 移除窗口
+                it = _activeWindows.erase(it);
+            }
+            else {
+                ++it;
+            }
+        }
+
+        if (!results.empty()) {
+            logger::info("[Haptics][Scorer] Returning {} haptic sources", results.size());
+        }
+
+        return results;
+    }
+
+    EventWindowScorer::Stats EventWindowScorer::GetStats() const
+    {
+        Stats s;
+        s.totalEvents = _totalEvents.load(std::memory_order_relaxed);
+        s.totalMatched = _totalMatched.load(std::memory_order_relaxed);
+        s.totalUnmatched = _totalUnmatched.load(std::memory_order_relaxed);
+
+        {
+            std::scoped_lock lock(_mutex);
+            s.activeWindows = static_cast<std::uint32_t>(_activeWindows.size());
+        }
+
+        return s;
+    }
+
+    float EventWindowScorer::ScoreFeature(const EventMsg& event, const AudioFeatureMsg& feature,
+        std::uint64_t eventQpc) const
+    {
+        auto& config = HapticsConfig::GetSingleton();
+
+        float scoreTiming = ScoreTiming(eventQpc, feature.qpcStart,
+            config.windowPreMs + config.windowPostMs);
+        float scoreAttack = ScoreAttack(event.type, feature.attack);
+        float scoreSpectrum = ScoreSpectrum(event.type, feature);
+        float scoreDuration = ScoreDuration(event.type, feature.qpcEnd - feature.qpcStart);
+        float scoreChannel = ScoreChannel(event.type, feature.energyL, feature.energyR);
+
+        float total = scoreTiming * config.weightTiming
+            + scoreAttack * config.weightAttack
+            + scoreSpectrum * config.weightSpectrum
+            + scoreDuration * config.weightDuration
+            + scoreChannel * config.weightChannel;
+
+        return std::clamp(total, 0.0f, 1.0f);
+    }
+
+    float EventWindowScorer::ScoreTiming(std::uint64_t eventQpc, std::uint64_t featureQpc,
+        std::uint64_t windowDuration) const
+    {
+        // 时序分：离事件越近分越高
+        std::int64_t delta = static_cast<std::int64_t>(featureQpc) - static_cast<std::int64_t>(eventQpc);
+        float absDelta = static_cast<float>(std::abs(delta));
+        float windowUs = static_cast<float>(windowDuration) * 1000.0f;
+
+        if (windowUs <= 0.0f) return 0.0f;
+
+        float normalized = 1.0f - (absDelta / windowUs);
+        return std::clamp(normalized, 0.0f, 1.0f);
+    }
+
+    float EventWindowScorer::ScoreAttack(EventType eventType, float attack) const
+    {
+        // 瞬态分：不同事件类型期望不同的瞬态强度
+        switch (eventType) {
+        case EventType::HitImpact:
+        case EventType::WeaponSwing:
+        case EventType::Block:
+            // 期望高瞬态
+            return attack;
+
+        case EventType::Footstep:
+        case EventType::Land:
+            // 期望中等瞬态
+            return std::clamp(attack * 1.5f, 0.0f, 1.0f);
+
+        case EventType::SpellCast:
+        case EventType::SpellImpact:
+            // 可能低瞬态
+            return std::clamp(attack * 0.8f + 0.2f, 0.0f, 1.0f);
+
+        default:
+            return attack;
+        }
+    }
+
+    float EventWindowScorer::ScoreSpectrum(EventType eventType, const AudioFeatureMsg& feature) const
+    {
+        // 频谱分：不同事件类型期望不同的频段分布
+        switch (eventType) {
+        case EventType::WeaponSwing:
+        case EventType::HitImpact:
+            // 期望中高频
+            return (feature.bandMid * 0.6f + feature.bandHigh * 0.4f);
+
+        case EventType::Footstep:
+        case EventType::Land:
+            // 期望低频
+            return feature.bandLow;
+
+        case EventType::SpellCast:
+        case EventType::SpellImpact:
+            // 期望宽带
+            return (feature.bandLow + feature.bandMid + feature.bandHigh) / 3.0f;
+
+        default:
+            return feature.rms;
+        }
+    }
+
+    float EventWindowScorer::ScoreDuration(EventType eventType, std::uint64_t durationUs) const
+    {
+        // 持续时长分：不同事件类型期望不同的持续时间
+        float durationMs = static_cast<float>(durationUs) / 1000.0f;
+
+        switch (eventType) {
+        case EventType::Footstep:
+        case EventType::HitImpact:
+            // 期望短促（< 100ms）
+            if (durationMs < 100.0f) return 1.0f;
+            return std::max(0.0f, 1.0f - (durationMs - 100.0f) / 200.0f);
+
+        case EventType::SpellCast:
+        case EventType::Shout:
+            // 期望较长（100-500ms）
+            if (durationMs >= 100.0f && durationMs <= 500.0f) return 1.0f;
+            if (durationMs < 100.0f) return durationMs / 100.0f;
+            return std::max(0.0f, 1.0f - (durationMs - 500.0f) / 500.0f);
+
+        default:
+            return 0.5f;
+        }
+    }
+
+    float EventWindowScorer::ScoreChannel(EventType eventType, float energyL, float energyR) const
+    {
+        // 声道分：可用于辅助判断（例如左右脚步）
+        // 当前简化实现：返回总能量
+        (void)eventType;
+        return (energyL + energyR) * 0.5f;
+    }
+
+    HapticSourceMsg EventWindowScorer::CreateBaseEventPulse(const EventMsg& event) const
+    {
+        auto& config = HapticsConfig::GetSingleton();
+
+        HapticSourceMsg msg;
+        msg.qpc = event.qpc;
+        msg.type = SourceType::BaseEvent;
+        msg.eventType = event.type;  // ✅ 关键：传递事件类型
+        msg.confidence = 1.0f;
+        msg.priority = GetPriorityForEvent(event.type);
+        msg.ttlMs = GetTTLForEvent(event.type);
+
+        // 根据事件类型设置基础强度
+        float baseIntensity = 0.5f;
+
+        switch (event.type) {
+        case EventType::HitImpact:
+            baseIntensity = config.basePulseHit;
+            break;
+        case EventType::WeaponSwing:
+            baseIntensity = config.basePulseSwing;
+            break;
+        case EventType::Footstep:
+            baseIntensity = config.basePulseFootstep;
+            break;
+        default:
+            baseIntensity = 0.5f;
+            break;
+        }
+
+        msg.left = baseIntensity * event.intensity;
+        msg.right = baseIntensity * event.intensity;
+
+        return msg;
+    }
+
+    HapticSourceMsg EventWindowScorer::CreateAudioModulation(const EventMsg& event,
+        const AudioFeatureMsg& feature, float confidence) const
+    {
+        HapticSourceMsg msg;
+        msg.qpc = feature.qpcStart;
+        msg.type = SourceType::AudioMod;
+        msg.eventType = event.type;  // ✅ 关键：传递事件类型
+        msg.confidence = confidence;
+        msg.priority = GetPriorityForEvent(event.type);
+        msg.ttlMs = GetTTLForEvent(event.type);
+
+        // 使用音频特征调制强度
+        float intensity = feature.rms * event.intensity * confidence;
+
+        msg.left = std::clamp(intensity * feature.energyL, 0.0f, 1.0f);
+        msg.right = std::clamp(intensity * feature.energyR, 0.0f, 1.0f);
+
+        return msg;
+    }
+
+    int EventWindowScorer::GetPriorityForEvent(EventType type) const
+    {
+        auto& config = HapticsConfig::GetSingleton();
+
+        switch (type) {
+        case EventType::HitImpact:
+        case EventType::Block:
+            return config.priorityHit;
+
+        case EventType::SpellCast:
+        case EventType::SpellImpact:
+        case EventType::Shout:
+            return config.prioritySpell;
+
+        case EventType::WeaponSwing:
+        case EventType::BowRelease:
+            return config.prioritySwing;
+
+        case EventType::Footstep:
+        case EventType::Jump:
+        case EventType::Land:
+            return config.priorityFootstep;
+
+        default:
+            return 50;
+        }
+    }
+
+    std::uint32_t EventWindowScorer::GetTTLForEvent(EventType type) const
+    {
+        // TTL（生存时间）：不同事件类型的触觉持续时间
+        switch (type) {
+        case EventType::HitImpact:
+        case EventType::Block:
+            return 80;  // 80ms
+
+        case EventType::WeaponSwing:
+            return 120;
+
+        case EventType::Footstep:
+            return 60;
+
+        case EventType::SpellCast:
+        case EventType::SpellImpact:
+            return 200;
+
+        case EventType::Shout:
+            return 300;
+
+        default:
+            return 100;
+        }
+    }
+}
