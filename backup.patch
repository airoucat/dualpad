diff --git a/src/haptics/XAPOTap.cpp b/src/haptics/XAPOTap.cpp
new file mode 100644
index 0000000..1c3ad95
--- /dev/null
+++ b/src/haptics/XAPOTap.cpp
@@ -0,0 +1,311 @@
+#include "pch.h"
+#include "haptics/XAPOTap.h"
+#include "haptics/VoiceManager.h"
+#include <SKSE/SKSE.h>
+#include <cmath>
+#include <algorithm>
+
+namespace logger = SKSE::log;
+
+namespace dualpad::haptics
+{
+    namespace
+    {
+        // 简单 RMS 计算
+        inline float ComputeRMS(const float* samples, std::uint32_t count)
+        {
+            if (count == 0) return 0.0f;
+
+            float sum = 0.0f;
+            for (std::uint32_t i = 0; i < count; ++i) {
+                sum += samples[i] * samples[i];
+            }
+            return std::sqrt(sum / static_cast<float>(count));
+        }
+
+        // 峰值
+        inline float ComputePeak(const float* samples, std::uint32_t count)
+        {
+            float peak = 0.0f;
+            for (std::uint32_t i = 0; i < count; ++i) {
+                peak = std::max(peak, std::abs(samples[i]));
+            }
+            return peak;
+        }
+
+        // 瞬态检测（简化版：首帧峰值 / RMS 比值）
+        inline float ComputeAttack(const float* samples, std::uint32_t count)
+        {
+            if (count < 8) return 0.0f;
+
+            float firstPeak = ComputePeak(samples, 8);
+            float rms = ComputeRMS(samples, count);
+
+            if (rms < 0.001f) return 0.0f;
+
+            return std::min(firstPeak / rms, 10.0f) / 10.0f;  // 归一化到 0..1
+        }
+
+        // 立体声能量
+        inline void ComputeStereoEnergy(const float* samples, std::uint32_t frameCount, std::uint16_t channels,
+            float& outL, float& outR)
+        {
+            outL = 0.0f;
+            outR = 0.0f;
+
+            if (channels == 1) {
+                outL = outR = ComputeRMS(samples, frameCount);
+                return;
+            }
+
+            if (channels == 2) {
+                float sumL = 0.0f, sumR = 0.0f;
+                for (std::uint32_t i = 0; i < frameCount; ++i) {
+                    sumL += samples[i * 2 + 0] * samples[i * 2 + 0];
+                    sumR += samples[i * 2 + 1] * samples[i * 2 + 1];
+                }
+                outL = std::sqrt(sumL / static_cast<float>(frameCount));
+                outR = std::sqrt(sumR / static_cast<float>(frameCount));
+                return;
+            }
+
+            // 多声道：简化为前两个声道
+            outL = outR = ComputeRMS(samples, frameCount * channels) / std::sqrt(static_cast<float>(channels));
+        }
+    }
+
+    DualSenseXAPOTap::DualSenseXAPOTap(const XAPOTapParams& params)
+        : CXAPOBase(nullptr)  // 无参数（我们不需要动态参数）
+        , _params(params)
+    {
+        // 预分配单声道缓冲（最大 1024 帧）
+        _monoBuffer.resize(1024);
+
+        ResetBandStates();
+    }
+
+    DualSenseXAPOTap::~DualSenseXAPOTap()
+    {
+        // 清理
+    }
+
+    HRESULT DualSenseXAPOTap::QueryInterface(REFIID riid, void** ppvObject)
+    {
+        if (!ppvObject) {
+            return E_POINTER;
+        }
+
+        if (riid == __uuidof(IUnknown) || riid == __uuidof(IXAPO)) {
+            *ppvObject = static_cast<IXAPO*>(this);
+            AddRef();
+            return S_OK;
+        }
+
+        *ppvObject = nullptr;
+        return E_NOINTERFACE;
+    }
+
+    ULONG DualSenseXAPOTap::AddRef()
+    {
+        return _refCount.fetch_add(1, std::memory_order_relaxed) + 1;
+    }
+
+    ULONG DualSenseXAPOTap::Release()
+    {
+        ULONG newCount = _refCount.fetch_sub(1, std::memory_order_acq_rel) - 1;
+        if (newCount == 0) {
+            delete this;
+        }
+        return newCount;
+    }
+
+    HRESULT DualSenseXAPOTap::LockForProcess(
+        UINT32 InputLockedParameterCount,
+        const XAPO_LOCKFORPROCESS_BUFFER_PARAMETERS* pInputLockedParameters,
+        UINT32 OutputLockedParameterCount,
+        const XAPO_LOCKFORPROCESS_BUFFER_PARAMETERS* pOutputLockedParameters)
+    {
+        // 调用基类
+        HRESULT hr = CXAPOBase::LockForProcess(
+            InputLockedParameterCount, pInputLockedParameters,
+            OutputLockedParameterCount, pOutputLockedParameters);
+
+        if (FAILED(hr)) {
+            return hr;
+        }
+
+        // 提取格式信息
+        if (InputLockedParameterCount > 0 && pInputLockedParameters) {
+            auto* fmt = pInputLockedParameters[0].pFormat;
+            if (fmt) {
+                _sampleRate = fmt->nSamplesPerSec;
+                _channels = fmt->nChannels;
+
+                // 检查是否为浮点格式
+                if (fmt->wFormatTag == WAVE_FORMAT_IEEE_FLOAT) {
+                    _isFloat = true;
+                }
+                else if (fmt->wFormatTag == WAVE_FORMAT_EXTENSIBLE) {
+                    auto* fmtEx = reinterpret_cast<const WAVEFORMATEXTENSIBLE*>(fmt);
+                    _isFloat = (fmtEx->SubFormat == KSDATAFORMAT_SUBTYPE_IEEE_FLOAT);
+                }
+                else {
+                    _isFloat = false;
+                }
+            }
+        }
+
+        return S_OK;
+    }
+
+    void DualSenseXAPOTap::Process(
+        UINT32 InputProcessParameterCount,
+        const XAPO_PROCESS_BUFFER_PARAMETERS* pInputProcessParameters,
+        UINT32 OutputProcessParameterCount,
+        XAPO_PROCESS_BUFFER_PARAMETERS* pOutputProcessParameters,
+        BOOL IsEnabled)
+    {
+        // 参数检查
+        if (InputProcessParameterCount == 0 || OutputProcessParameterCount == 0 ||
+            !pInputProcessParameters || !pOutputProcessParameters) {
+            return;
+        }
+
+        auto* input = &pInputProcessParameters[0];
+        auto* output = &pOutputProcessParameters[0];
+
+        if (!input->pBuffer || !output->pBuffer) {
+            return;
+        }
+
+        const std::uint32_t frameCount = input->ValidFrameCount;
+        if (frameCount == 0) {
+            output->ValidFrameCount = 0;
+            return;
+        }
+
+        // 透传音频（直接复制）
+        if (input->pBuffer != output->pBuffer) {
+            const std::uint32_t byteCount = frameCount * _channels * sizeof(float);
+            memcpy(output->pBuffer, input->pBuffer, byteCount);
+        }
+
+        output->ValidFrameCount = frameCount;
+        output->BufferFlags = input->BufferFlags;
+
+        // 提取特征并推送（如果启用）
+        if (IsEnabled && _params.enableFeatureExtraction && _isFloat) {
+            auto* samples = static_cast<const float*>(input->pBuffer);
+            ExtractAndPushFeatures(samples, frameCount);
+        }
+
+        _processedFrames.fetch_add(frameCount, std::memory_order_relaxed);
+    }
+
+    void DualSenseXAPOTap::ExtractAndPushFeatures(const float* samples, std::uint32_t frameCount)
+    {
+        // 计算特征
+        auto features = ComputeFeatures(samples, frameCount);
+
+        // 推送到 VoiceManager（无锁）
+        if (VoiceManager::GetSingleton().PushAudioFeature(features)) {
+            _pushedCount.fetch_add(1, std::memory_order_relaxed);
+        }
+        else {
+            _droppedCount.fetch_add(1, std::memory_order_relaxed);
+        }
+    }
+
+    AudioFeatureMsg DualSenseXAPOTap::ComputeFeatures(const float* samples, std::uint32_t frameCount)
+    {
+        AudioFeatureMsg msg;
+        msg.qpcStart = ToQPC(Now());
+        msg.voiceId = _params.voiceId;
+        msg.sampleRate = _sampleRate;
+        msg.channels = _channels;
+
+        const std::uint32_t sampleCount = frameCount * _channels;
+
+        // 基础特征
+        msg.rms = ComputeRMS(samples, sampleCount);
+        msg.peak = ComputePeak(samples, sampleCount);
+        msg.attack = ComputeAttack(samples, sampleCount);
+
+        // 立体声能量
+        ComputeStereoEnergy(samples, frameCount, _channels, msg.energyL, msg.energyR);
+
+        // 频段能量（简化实现：使用简单 IIR 滤波器）
+        // 注意：这里为了性能只做粗略估计
+        // 实际项目可以用更精确的 FFT 或 Biquad 滤波器
+
+        // 转换为单声道（如果是立体声）
+        std::uint32_t monoCount = frameCount;
+        const float* monoSamples = samples;
+
+        if (_channels == 2 && frameCount <= _monoBuffer.size()) {
+            for (std::uint32_t i = 0; i < frameCount; ++i) {
+                _monoBuffer[i] = (samples[i * 2 + 0] + samples[i * 2 + 1]) * 0.5f;
+            }
+            monoSamples = _monoBuffer.data();
+        }
+
+        // 简单频段分离（占位实现）
+        float sumLow = 0.0f, sumMid = 0.0f, sumHigh = 0.0f;
+
+        for (std::uint32_t i = 0; i < monoCount; ++i) {
+            float s = monoSamples[i];
+
+            float low = ProcessBandLow(s);
+            float mid = ProcessBandMid(s);
+            float high = ProcessBandHigh(s);
+
+            sumLow += low * low;
+            sumMid += mid * mid;
+            sumHigh += high * high;
+        }
+
+        msg.bandLow = std::sqrt(sumLow / static_cast<float>(monoCount));
+        msg.bandMid = std::sqrt(sumMid / static_cast<float>(monoCount));
+        msg.bandHigh = std::sqrt(sumHigh / static_cast<float>(monoCount));
+
+        msg.qpcEnd = ToQPC(Now());
+
+        return msg;
+    }
+
+    void DualSenseXAPOTap::ResetBandStates()
+    {
+        _bandLow = {};
+        _bandMid = {};
+        _bandHigh = {};
+    }
+
+    float DualSenseXAPOTap::ProcessBandLow(float sample)
+    {
+        // 简单一阶低通滤波器（截止频率约 250Hz @ 48kHz）
+        constexpr float alpha = 0.03f;
+        _bandLow.z1 = _bandLow.z1 + alpha * (sample - _bandLow.z1);
+        return _bandLow.z1;
+    }
+
+    float DualSenseXAPOTap::ProcessBandMid(float sample)
+    {
+        // 简单带通（中频）：高通 + 低通
+        constexpr float alphaHigh = 0.03f;
+        constexpr float alphaLow = 0.3f;
+
+        _bandMid.z1 = _bandMid.z1 + alphaHigh * (sample - _bandMid.z1);
+        float highPassed = sample - _bandMid.z1;
+
+        _bandMid.z2 = _bandMid.z2 + alphaLow * (highPassed - _bandMid.z2);
+        return _bandMid.z2;
+    }
+
+    float DualSenseXAPOTap::ProcessBandHigh(float sample)
+    {
+        // 简单一阶高通滤波器（截止频率约 2000Hz @ 48kHz）
+        constexpr float alpha = 0.2f;
+        _bandHigh.z1 = _bandHigh.z1 + alpha * (sample - _bandHigh.z1);
+        return sample - _bandHigh.z1;
+    }
+}
