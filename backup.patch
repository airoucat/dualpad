+#pragma once
+#include "haptics/HapticsTypes.h"
+#include "haptics/SPSCQueue.h"
+#include <cstdint>
+#include <unordered_map>
+#include <mutex>
+#include <memory>
+
+// 前向声明（避免引入 XAudio2 头文件）
+struct IXAudio2SourceVoice;
+struct IXAudio2;
+
+namespace dualpad::haptics
+{
+    // 新增：音频特征结构体
+    struct AudioFeature
+    {
+        float rms{ 0.0f };
+        float peak{ 0.0f };
+        float spectralCentroid{ 0.0f };
+        float zeroCrossingRate{ 0.0f };
+        float confidence{ 0.0f };
+    };
+    // Voice 信息
+    struct VoiceInfo
+    {
+        std::uint32_t voiceId{ 0 };
+        IXAudio2SourceVoice* voice{ nullptr };
+        std::uint32_t sampleRate{ 48000 };
+        std::uint16_t channels{ 2 };
+        TimePoint createTime;
+        bool hasTap{ false };
+    };
+
+    // Voice 管理器
+    // 负责跟踪所有 SourceVoice 并管理 XAPO Tap 的生命周期
+    class VoiceManager
+    {
+    public:
+        static VoiceManager& GetSingleton();
+
+        // 初始化（分配队列等）
+        void Initialize();
+
+        // 关闭（清理资源）
+        void Shutdown();
+
+        // Voice 生命周期回调（由 XAudio2Hook 调用）
+        void OnVoiceCreated(IXAudio2SourceVoice* voice, std::uint32_t sampleRate, std::uint16_t channels, bool allowTap = true);
+        void OnVoiceDestroyed(IXAudio2SourceVoice* voice);
+
+        // 从 XAPO Tap 推送音频特征（音频线程调用，无锁）
+        bool PushAudioFeature(const AudioFeatureMsg& msg);
+
+        // 消费者侧：批量获取音频特征（触觉线程调用）
+        std::size_t PopAudioFeatures(AudioFeatureMsg* out, std::size_t maxCount);
+
+        // 查询
+        std::size_t GetActiveVoiceCount() const;
+        std::size_t GetQueueSize() const;
+
+        // 统计
+        struct Stats
+        {
+            std::uint32_t totalCreated{ 0 };
+            std::uint32_t totalDestroyed{ 0 };
+            std::uint32_t activeCurrent{ 0 };
+            std::uint32_t tapInstalled{ 0 };
+            std::uint32_t featuresPushed{ 0 };
+            std::uint32_t featuresDropped{ 0 };
+        };
+
+        Stats GetStats() const;
+
+    private:
+        VoiceManager() = default;
+
+        mutable std::mutex _mutex;
+        std::unordered_map<IXAudio2SourceVoice*, VoiceInfo> _voices;
+
+        std::uint32_t _nextVoiceId{ 1 };
+
+        // 音频特征队列（SPSC，音频线程 -> 触觉线程）
+        std::unique_ptr<SPSCQueue<AudioFeatureMsg>> _featureQueue;
+
+        // 统计
+        std::atomic<std::uint32_t> _totalCreated{ 0 };
+        std::atomic<std::uint32_t> _totalDestroyed{ 0 };
+        std::atomic<std::uint32_t> _tapInstalled{ 0 };
+        std::atomic<std::uint32_t> _featuresPushed{ 0 };
+        std::atomic<std::uint32_t> _featuresDropped{ 0 };
+
+        bool _initialized{ false };
+
+        // 内部辅助
+        std::uint32_t AllocateVoiceId();
+        bool InstallTapOnVoice(VoiceInfo& info);
+    };
+}
