+
+struct IXAudio2;
+struct IXAudio2SourceVoice;
+
+namespace dualpad::haptics
+{
+    enum class XAudio2Version
+    {
+        Unknown = 0,
+        XAudio2_7,
+        XAudio2_8,
+        XAudio2_9
+    };
+
+    const char* ToString(XAudio2Version v);
+
+    class XAudio2Hook
+    {
+    public:
+        static XAudio2Hook& GetSingleton();
+
+        bool Install();
+        void Uninstall();
+
+        bool IsInstalled() const { return _installed.load(std::memory_order_acquire); }
