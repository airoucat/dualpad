+        bool enableFeatureExtraction{ true };
+        float gainCompensation{ 1.0f };
+    };
+
+    // DualSense XAPO Tap
+    // 透传音频 + 提取轻量特征 + 推送到 VoiceManager
+    class DualSenseXAPOTap : public CXAPOBase
+    {
+    public:
+        explicit DualSenseXAPOTap(const XAPOTapParams& params);
+        virtual ~DualSenseXAPOTap();
+
+        // IUnknown
+        STDMETHOD(QueryInterface)(REFIID riid, void** ppvObject) override;
+        STDMETHOD_(ULONG, AddRef)() override;
+        STDMETHOD_(ULONG, Release)() override;
+
+        // IXAPO
+        STDMETHOD(LockForProcess)(
+            UINT32 InputLockedParameterCount,
+            const XAPO_LOCKFORPROCESS_BUFFER_PARAMETERS* pInputLockedParameters,
+            UINT32 OutputLockedParameterCount,
+            const XAPO_LOCKFORPROCESS_BUFFER_PARAMETERS* pOutputLockedParameters) override;
+
+        STDMETHOD_(void, Process)(
+            UINT32 InputProcessParameterCount,
+            const XAPO_PROCESS_BUFFER_PARAMETERS* pInputProcessParameters,
+            UINT32 OutputProcessParameterCount,
+            XAPO_PROCESS_BUFFER_PARAMETERS* pOutputProcessParameters,
+            BOOL IsEnabled) override;
+
+        // 统计
+        std::uint64_t GetProcessedFrames() const { return _processedFrames.load(); }
+        std::uint64_t GetPushedCount() const { return _pushedCount.load(); }
+        std::uint64_t GetDroppedCount() const { return _droppedCount.load(); }
+
+    private:
+        XAPOTapParams _params;
+        std::atomic<ULONG> _refCount{ 1 };
+
+        // 格式信息（在 LockForProcess 中设置）
+        std::uint32_t _sampleRate{ 48000 };
+        std::uint16_t _channels{ 2 };
+        bool _isFloat{ true };
+
+        // 统计
+        std::atomic<std::uint64_t> _processedFrames{ 0 };
+        std::atomic<std::uint64_t> _pushedCount{ 0 };
+        std::atomic<std::uint64_t> _droppedCount{ 0 };
+
+        // 特征提取缓冲（避免每次分配）
+        std::vector<float> _monoBuffer;
+
+        // 内部辅助
+        void ExtractAndPushFeatures(const float* samples, std::uint32_t frameCount);
+        AudioFeatureMsg ComputeFeatures(const float* samples, std::uint32_t frameCount);
+
+        // 简单频段滤波器状态
+        struct BandState
+        {
+            float z1{ 0.0f };
+            float z2{ 0.0f };
+        };
+        BandState _bandLow, _bandMid, _bandHigh;
+
+        void ResetBandStates();
+        float ProcessBandLow(float sample);
+        float ProcessBandMid(float sample);
+        float ProcessBandHigh(float sample);
+    };
