new file mode 100644
index 0000000..7fc91bb
--- /dev/null
+++ b/src/haptics/VoiceManager.cpp
@@ -0,0 +1,200 @@
+#include "pch.h"
+#include "haptics/VoiceManager.h"
+#include "haptics/XAPOTap.h"
+#include "haptics/HapticsConfig.h"
+#include <SKSE/SKSE.h>
+#include <xaudio2.h>
+namespace logger = SKSE::log;
+
+namespace dualpad::haptics
+{
+    VoiceManager& VoiceManager::GetSingleton()
+    {
+        static VoiceManager instance;
+        return instance;
+    }
+
+    void VoiceManager::Initialize()
+    {
+        if (_initialized) {
+            logger::warn("[Haptics][VoiceManager] Already initialized");
+            return;
+        }
+
+        logger::info("[Haptics][VoiceManager] Initializing...");
+
+        auto& config = HapticsConfig::GetSingleton();
+
+        // 创建音频特征队列
+        _featureQueue = std::make_unique<SPSCQueue<AudioFeatureMsg>>(config.queueCapacity);
+
+        _initialized = true;
+
+        logger::info("[Haptics][VoiceManager] Initialized (queue capacity: {})", config.queueCapacity);
+    }
+
+    void VoiceManager::Shutdown()
+    {
+        if (!_initialized) {
+            return;
+        }
+
+        logger::info("[Haptics][VoiceManager] Shutting down...");
+
+        {
+            std::scoped_lock lock(_mutex);
+            _voices.clear();
+        }
+
+        _featureQueue.reset();
+        _initialized = false;
+
+        logger::info("[Haptics][VoiceManager] Shutdown complete");
+    }
+
+    void VoiceManager::OnVoiceCreated(
+        IXAudio2SourceVoice* voice,
+        std::uint32_t sampleRate,
+        std::uint16_t channels,
+        bool allowTap)
+    {
+        if (!voice || !_initialized) {
+            return;
+        }
+
+        std::scoped_lock lock(_mutex);
+
+        VoiceInfo info;
+        info.voiceId = AllocateVoiceId();
+        info.voice = voice;
+        info.sampleRate = sampleRate;
+        info.channels = channels;
+        info.createTime = Now();
+        info.hasTap = false;
+
+        // 尝试安装 Tap
+        if (allowTap && InstallTapOnVoice(info)) {
+            info.hasTap = true;
+            _tapInstalled.fetch_add(1, std::memory_order_relaxed);
+        }
+        if (!allowTap) {
+            logger::trace("[Haptics][VoiceManager] Skip tap install (allowTap=false)");
+        }
+
+        _voices[voice] = info;
+        _totalCreated.fetch_add(1, std::memory_order_relaxed);
+
+        logger::trace("[Haptics][VoiceManager] Voice created: id={} rate={} ch={} tap={}",
+            info.voiceId, sampleRate, channels, info.hasTap);
+    }
+
+    void VoiceManager::OnVoiceDestroyed(IXAudio2SourceVoice* voice)
+    {
+        if (!voice || !_initialized) {
+            return;
+        }
+
+        std::scoped_lock lock(_mutex);
+
+        auto it = _voices.find(voice);
+        if (it != _voices.end()) {
+            logger::trace("[Haptics][VoiceManager] Voice destroyed: id={}", it->second.voiceId);
+            _voices.erase(it);
+            _totalDestroyed.fetch_add(1, std::memory_order_relaxed);
+        }
+    }
+
+    bool VoiceManager::PushAudioFeature(const AudioFeatureMsg& msg)
+    {
+        if (!_initialized || !_featureQueue) {
+            return false;
+        }
+
+        if (_featureQueue->TryPush(msg)) {
+            _featuresPushed.fetch_add(1, std::memory_order_relaxed);
+            return true;
+        }
+
+        // 队列满，丢弃
+        _featuresDropped.fetch_add(1, std::memory_order_relaxed);
+        return false;
+    }
+
+    std::size_t VoiceManager::PopAudioFeatures(AudioFeatureMsg* out, std::size_t maxCount)
+    {
+        if (!_initialized || !_featureQueue || !out) {
+            return 0;
+        }
+
+        return _featureQueue->PopBatch(out, maxCount);
+    }
+
+    std::size_t VoiceManager::GetActiveVoiceCount() const
+    {
+        std::scoped_lock lock(_mutex);
+        return _voices.size();
+    }
+
+    std::size_t VoiceManager::GetQueueSize() const
+    {
+        if (!_initialized || !_featureQueue) {
+            return 0;
+        }
+
+        return _featureQueue->SizeApprox();
+    }
+
+    VoiceManager::Stats VoiceManager::GetStats() const
+    {
+        Stats s;
+        s.totalCreated = _totalCreated.load(std::memory_order_relaxed);
+        s.totalDestroyed = _totalDestroyed.load(std::memory_order_relaxed);
+        s.activeCurrent = static_cast<std::uint32_t>(GetActiveVoiceCount());
+        s.tapInstalled = _tapInstalled.load(std::memory_order_relaxed);
+        s.featuresPushed = _featuresPushed.load(std::memory_order_relaxed);
+        s.featuresDropped = _featuresDropped.load(std::memory_order_relaxed);
+        return s;
+    }
+
+    std::uint32_t VoiceManager::AllocateVoiceId()
+    {
+        return _nextVoiceId++;
+    }
+
+    bool VoiceManager::InstallTapOnVoice(VoiceInfo& info)
+    {
+        if (!info.voice) {
+            return false;
+        }
+
+        // 创建 XAPO Tap
+        XAPOTapParams params;
+        params.voiceId = info.voiceId;
+        params.enableFeatureExtraction = true;
+
+        auto* tap = new DualSenseXAPOTap(params);
+
+        // 构建 Effect Chain
+        XAUDIO2_EFFECT_DESCRIPTOR descriptor;
+        descriptor.pEffect = tap;
+        descriptor.InitialState = TRUE;
+        descriptor.OutputChannels = info.channels;
+
+        XAUDIO2_EFFECT_CHAIN chain;
+        chain.EffectCount = 1;
+        chain.pEffectDescriptors = &descriptor;
+
+        // 设置到 voice
+        HRESULT hr = info.voice->SetEffectChain(&chain);
+
+        if (FAILED(hr)) {
+            logger::warn("[Haptics][VoiceManager] Failed to set effect chain: {:X}",
+                static_cast<uint32_t>(hr));
+            tap->Release();
+            return false;
+        }
+
+        logger::trace("[Haptics][VoiceManager] XAPO Tap installed on voice {}", info.voiceId);
+        return true;
+    }
+}
