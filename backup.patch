+++ b/src/haptics/EventQueue.h
@@ -0,0 +1,42 @@
+#pragma once
+#include "haptics/HapticsTypes.h"
+#include <vector>
+#include <mutex>
+#include <atomic>
+
+namespace dualpad::haptics
+{
+    // 事件队列（MPSC: Multiple Producer, Single Consumer）
+    // 用于从游戏线程收集事件，在触觉线程消费
+    class EventQueue
+    {
+    public:
+        static EventQueue& GetSingleton();
+
+        // 初始化队列
+        void Initialize(std::size_t capacity = 1024);
+
+        // 推送事件（生产者，多线程安全）
+        bool Push(const EventMsg& msg);  // 只声明，不实现
+
+        // 拉取所有事件（消费者，单线程）
+        std::vector<EventMsg> DrainAll();
+
+        // 统计
+        std::size_t Size() const;
+        std::uint32_t GetPushedCount() const { return _pushed.load(std::memory_order_relaxed); }
+        std::uint32_t GetDroppedCount() const { return _dropped.load(std::memory_order_relaxed); }
+
+    private:
+        EventQueue() = default;
+
+        mutable std::mutex _mutex;
+        std::vector<EventMsg> _queue;
+        std::size_t _capacity{ 1024 };
+
+        std::atomic<std::uint32_t> _pushed{ 0 };
+        std::atomic<std::uint32_t> _dropped{ 0 };
+
+        bool _initialized{ false };
+    };
+}
