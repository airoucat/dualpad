@@ -0,0 +1,59 @@
+#include "pch.h"
+#include "haptics/EventQueue.h"
+#include <SKSE/SKSE.h>
+
+namespace logger = SKSE::log;
+
+namespace dualpad::haptics
+{
+    EventQueue& EventQueue::GetSingleton()
+    {
+        static EventQueue instance;
+        return instance;
+    }
+
+    void EventQueue::Initialize(std::size_t capacity)
+    {
+        if (_initialized) {
+            logger::warn("[Haptics][EventQueue] Already initialized");
+            return;
+        }
+
+        _capacity = capacity;
+        _queue.reserve(capacity);
+        _initialized = true;
+
+        logger::info("[Haptics][EventQueue] Initialized (capacity: {})", capacity);
+    }
+
+    bool EventQueue::Push(const EventMsg& msg)
+    {
+        std::scoped_lock lock(_mutex);
+
+        if (_queue.size() >= _capacity) {
+            _dropped.fetch_add(1, std::memory_order_relaxed);
+            return false;  // 队列满
+        }
+
+        _queue.push_back(msg);
+        _pushed.fetch_add(1, std::memory_order_relaxed);
+        logger::info("[Haptics][EventQueue] push type={} size={}",
+            ToString(msg.type), _queue.size());
+        return true;  // 成功
+    }
+
+    std::vector<EventMsg> EventQueue::DrainAll()
+    {
+        std::scoped_lock lock(_mutex);
+
+        std::vector<EventMsg> result;
+        result.swap(_queue);
+        return result;
+    }
+
+    std::size_t EventQueue::Size() const
+    {
+        std::scoped_lock lock(_mutex);
+        return _queue.size();
+    }
+}
