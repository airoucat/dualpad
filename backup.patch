+#pragma once
+#include "haptics/HapticsTypes.h"
+#include <vector>
+#include <unordered_map>
+#include <mutex>
+
+namespace dualpad::haptics
+{
+    // 事件窗口（用于匹配音频特征）
+    struct EventWindow
+    {
+        EventMsg event;
+        TimePoint windowStart;
+        TimePoint windowEnd;
+        bool resolved{ false };
+
+        // 候选音频特征
+        std::vector<AudioFeatureMsg> candidates;
+
+        // 最佳匹配结果
+        AudioFeatureMsg bestMatch;
+        float bestScore{ 0.0f };
+        bool hasMatch{ false };
+    };
+
+    // 事件窗口打分器
+    // 负责将游戏事件与音频特征进行匹配打分
+    class EventWindowScorer
+    {
+    public:
+        static EventWindowScorer& GetSingleton();
+
+        // 初始化
+        void Initialize();
+
+        // 关闭
+        void Shutdown();
+
+        // 添加新事件（创建窗口）
+        void AddEvent(const EventMsg& event);
+
+        // 添加音频特征（尝试匹配到活跃窗口）
+        void AddAudioFeature(const AudioFeatureMsg& feature);
+
+        // 更新所有窗口（检查超时、计算最佳匹配）
+        // 返回已解析的触觉源消息
+        std::vector<HapticSourceMsg> Update();
+
+        // 统计
+        struct Stats
+        {
+            std::uint32_t totalEvents{ 0 };
+            std::uint32_t totalMatched{ 0 };
+            std::uint32_t totalUnmatched{ 0 };
+            std::uint32_t activeWindows{ 0 };
+        };
+
+        Stats GetStats() const;
+
+    private:
+        EventWindowScorer() = default;
+
+        mutable std::mutex _mutex;
+        std::vector<EventWindow> _activeWindows;
+
+        bool _initialized{ false };
+
+        // 统计
+        std::atomic<std::uint32_t> _totalEvents{ 0 };
+        std::atomic<std::uint32_t> _totalMatched{ 0 };
+        std::atomic<std::uint32_t> _totalUnmatched{ 0 };
+
+        // 内部辅助
+        float ScoreFeature(const EventMsg& event, const AudioFeatureMsg& feature,
+            std::uint64_t eventQpc) const;
+
+        float ScoreTiming(std::uint64_t eventQpc, std::uint64_t featureQpc,
+            std::uint64_t windowDuration) const;
+
+        float ScoreAttack(EventType eventType, float attack) const;
+        float ScoreSpectrum(EventType eventType, const AudioFeatureMsg& feature) const;
+        float ScoreDuration(EventType eventType, std::uint64_t duration) const;
+        float ScoreChannel(EventType eventType, float energyL, float energyR) const;
+
+        HapticSourceMsg CreateBaseEventPulse(const EventMsg& event) const;
+        HapticSourceMsg CreateAudioModulation(const EventMsg& event,
+            const AudioFeatureMsg& feature, float confidence) const;
+
+        int GetPriorityForEvent(EventType type) const;
+        std::uint32_t GetTTLForEvent(EventType type) const;
+    };
+}
