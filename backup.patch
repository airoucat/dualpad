+    private:
+        XAudio2Hook() = default;
+        ~XAudio2Hook() = default;
+        XAudio2Hook(const XAudio2Hook&) = delete;
+        XAudio2Hook& operator=(const XAudio2Hook&) = delete;
+
+        bool ResolveXAudio2Create();
+        bool ProbeCreateSourceVoiceTarget(void** outTarget);
+        bool ProbeSubmitSourceBufferTargetFromVoice(IXAudio2SourceVoice* voice, void** outTarget);
+        bool ProbeDestroyVoiceTargetFromVoice(IXAudio2SourceVoice* voice, void** outTarget);
+
+        mutable std::mutex _lock;
+        std::atomic<bool> _installed{ false };
+
+        XAudio2Version _version{ XAudio2Version::Unknown };
+        HMODULE _xaudioModule{ nullptr };
+        void* _xaudio2CreateProc{ nullptr };
+
+        void* _targetCreateSourceVoice{ nullptr };
+        void* _targetSubmitSourceBuffer{ nullptr };
+        void* _targetDestroyVoice{ nullptr };
+        std::atomic<bool> _createSourceVoiceHooked{ false };
+        std::atomic<bool> _submitBufferHooked{ false };
+        std::atomic<bool> _destroyHookInstalled{ false };
+    };
+}
