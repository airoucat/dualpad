@@ -0,0 +1,331 @@
+#include "pch.h"
+#include "haptics/HapticsConfig.h"
+#include <SKSE/SKSE.h>
+#include <fstream>
+#include <cstdio>
+#include <sstream>
+#include <unordered_map>
+
+namespace logger = SKSE::log;
+
+namespace dualpad::haptics
+{
+    namespace
+    {
+        inline std::string Trim(std::string s)
+        {
+            auto isSpace = [](unsigned char c) {
+                return c == ' ' || c == '\t' || c == '\r' || c == '\n';
+                };
+
+            while (!s.empty() && isSpace(static_cast<unsigned char>(s.front()))) {
+                s.erase(s.begin());
+            }
+            while (!s.empty() && isSpace(static_cast<unsigned char>(s.back()))) {
+                s.pop_back();
+            }
+            return s;
+        }
+    }
+
+    HapticsConfig& HapticsConfig::GetSingleton()
+    {
+        static HapticsConfig instance;
+        return instance;
+    }
+
+    std::filesystem::path HapticsConfig::GetDefaultPath()
+    {
+        return "Data/SKSE/Plugins/DualPadHaptics.ini";
+    }
+
+    bool HapticsConfig::Load(const std::filesystem::path& path)
+    {
+        auto configPath = path.empty() ? GetDefaultPath() : path;
+
+        logger::info("[Haptics][Config] Loading from: {}", configPath.string());
+
+        if (!std::filesystem::exists(configPath)) {
+            logger::warn("[Haptics][Config] Config file not found, using defaults");
+            return false;
+        }
+
+        return ParseIniFile(configPath);
+    }
+
+    bool HapticsConfig::ParseIniFile(const std::filesystem::path& path)
+    {
+        std::ifstream ifs(path);
+        if (!ifs.is_open()) {
+            logger::error("[Haptics][Config] Failed to open: {}", path.string());
+            return false;
+        }
+
+        std::string currentSection;
+        std::string line;
+        std::size_t lineNo = 0;
+        std::unordered_map<std::string, std::unordered_map<std::string, std::string>> sections;
+
+        while (std::getline(ifs, line)) {
+            ++lineNo;
+
+            // 去除 BOM
+            if (lineNo == 1 && line.size() >= 3 &&
+                static_cast<unsigned char>(line[0]) == 0xEF &&
+                static_cast<unsigned char>(line[1]) == 0xBB &&
+                static_cast<unsigned char>(line[2]) == 0xBF) {
+                line.erase(0, 3);
+            }
+
+            line = Trim(line);
+
+            if (line.empty() || line[0] == ';' || line[0] == '#') {
+                continue;
+            }
+
+            if (line.front() == '[' && line.back() == ']') {
+                currentSection = Trim(line.substr(1, line.size() - 2));
+                continue;
+            }
+
+            auto eqPos = line.find('=');
+            if (eqPos == std::string::npos) {
+                continue;
+            }
+
+            auto key = Trim(line.substr(0, eqPos));
+            auto value = Trim(line.substr(eqPos + 1));
+
+            if (key.empty() || value.empty()) {
+                continue;
+            }
+
+            sections[currentSection][key] = value;
+        }
+
+        // 解析各个 section
+        for (const auto& [section, values] : sections) {
+            try {
+                if (section == "Core") {
+                    if (values.count("enabled")) enabled = (values.at("enabled") == "true");
+                    if (values.count("tick_ms")) tickMs = std::stoul(values.at("tick_ms"));
+                    if (values.count("use_qpc")) useQpc = (values.at("use_qpc") == "true");
+                    if (values.count("hot_reload")) hotReload = (values.at("hot_reload") == "true");
+                }
+                else if (section == "AudioTap") {
+                    if (values.count("block_prefer_samples")) blockPreferSamples = std::stoul(values.at("block_prefer_samples"));
+                    if (values.count("queue_capacity")) queueCapacity = std::stoul(values.at("queue_capacity"));
+                }
+                else if (section == "Scoring") {
+                    if (values.count("window_pre_ms")) windowPreMs = std::stoul(values.at("window_pre_ms"));
+                    if (values.count("window_post_ms")) windowPostMs = std::stoul(values.at("window_post_ms"));
+                    if (values.count("min_confidence")) minConfidence = std::stof(values.at("min_confidence"));
+                    if (values.count("weight_timing")) weightTiming = std::stof(values.at("weight_timing"));
+                    if (values.count("weight_attack")) weightAttack = std::stof(values.at("weight_attack"));
+                    if (values.count("weight_spectrum")) weightSpectrum = std::stof(values.at("weight_spectrum"));
+                    if (values.count("weight_duration")) weightDuration = std::stof(values.at("weight_duration"));
+                    if (values.count("weight_channel")) weightChannel = std::stof(values.at("weight_channel"));
+                }
+                else if (section == "Mixer") {
+                    if (values.count("limiter")) limiter = std::stof(values.at("limiter"));
+                    if (values.count("compressor_attack_ms")) compressorAttackMs = std::stoul(values.at("compressor_attack_ms"));
+                    if (values.count("compressor_release_ms")) compressorReleaseMs = std::stoul(values.at("compressor_release_ms"));
+                    if (values.count("slew_per_tick")) slewPerTick = std::stof(values.at("slew_per_tick"));
+                    if (values.count("deadzone")) deadzone = std::stof(values.at("deadzone"));
+                }
+                else if (section == "Ducking") {
+                    if (values.count("hit_duck_footstep")) hitDuckFootstep = std::stof(values.at("hit_duck_footstep"));
+                    if (values.count("hit_duck_ambient")) hitDuckAmbient = std::stof(values.at("hit_duck_ambient"));
+                    if (values.count("spell_duck_footstep")) spellDuckFootstep = std::stof(values.at("spell_duck_footstep"));
+                }
+                else if (section == "Priority") {
+                    if (values.count("hit")) priorityHit = std::stoi(values.at("hit"));
+                    if (values.count("spell")) prioritySpell = std::stoi(values.at("spell"));
+                    if (values.count("swing")) prioritySwing = std::stoi(values.at("swing"));
+                    if (values.count("footstep")) priorityFootstep = std::stoi(values.at("footstep"));
+                    if (values.count("ambient")) priorityAmbient = std::stoi(values.at("ambient"));
+                }
+                else if (section == "Fallback") {
+                    if (values.count("enable_base_pulse")) enableBasePulse = (values.at("enable_base_pulse") == "true");
+                    if (values.count("base_pulse_hit")) basePulseHit = std::stof(values.at("base_pulse_hit"));
+                    if (values.count("base_pulse_swing")) basePulseSwing = std::stof(values.at("base_pulse_swing"));
+                    if (values.count("base_pulse_footstep")) basePulseFootstep = std::stof(values.at("base_pulse_footstep"));
+                }
+                else if (section == "Device") {
+                    if (values.count("output_backend")) outputBackend = values.at("output_backend");
+                    if (values.count("retry_count")) retryCount = std::stoul(values.at("retry_count"));
+                    if (values.count("reconnect_ms")) reconnectMs = std::stoul(values.at("reconnect_ms"));
+                }
+                else if (section == "Debug") {
+                    if (values.count("log_level")) logLevel = values.at("log_level");
+                    if (values.count("stats_interval_ms")) statsIntervalMs = std::stoul(values.at("stats_interval_ms"));
+                    if (values.count("dump_metrics")) dumpMetrics = (values.at("dump_metrics") == "true");
+                }
+                else if (section == "Mode") {
+                    LoadModeConfig(section, values);
+                }
+                else if (section == "EventPriority") {
+                    LoadEventPriorityConfig(section, values);
+                }
+                else if (section == "DuckingMatrix") {
+                    LoadDuckingMatrix(section, values);
+                }
+                else if (section == "ExtensionAPI") {
+                    LoadExtensionConfig(section, values);
+                }
+            }
+            catch (const std::exception& e) {
+                logger::warn("[Haptics][Config] Parse error in section [{}]: {}",
+                    section, e.what());
+            }
+        }
+        logger::info("[Haptics][Config] Config loaded successfully");
+        return true;
+    }
+    void HapticsConfig::LoadModeConfig(const std::string& section,
+        const std::unordered_map<std::string, std::string>& values)
+    {
+        if (values.count("haptics_mode")) {
+            const auto& modeStr = values.at("haptics_mode");
+            if (modeStr == "NativeOnly") {
+                hapticsMode = HapticsMode::NativeOnly;
+            }
+            else if (modeStr == "AudioDriven") {
+                hapticsMode = HapticsMode::AudioDriven;
+            }
+            else {
+                hapticsMode = HapticsMode::Hybrid;
+            }
+        }
+
+        if (values.count("allow_subtle_events_without_audio")) {
+            allowSubtleEventsWithoutAudio = (values.at("allow_subtle_events_without_audio") == "true");
+        }
+
+        logger::info("[Haptics][Config] Mode: {} SubtleWithoutAudio: {}",
+            static_cast<int>(hapticsMode), allowSubtleEventsWithoutAudio);
+
+        if (values.count("audio_driven_prefer_audio_only")) {
+            audioDrivenPreferAudioOnly = (values.at("audio_driven_prefer_audio_only") == "true");
+        }
+        if (values.count("fallback_base_when_no_match")) {
+            fallbackBaseWhenNoMatch = (values.at("fallback_base_when_no_match") == "true");
+        }
+
+        logger::info("[Haptics][Config] AudioDrivenPreferAudioOnly: {} FallbackBaseWhenNoMatch: {}",
+            audioDrivenPreferAudioOnly, fallbackBaseWhenNoMatch);
+    }
+    void HapticsConfig::LoadEventPriorityConfig(const std::string& section,
+        const std::unordered_map<std::string, std::string>& values)
+    {
+        for (const auto& [key, value] : values) {
+            EventType type = StringToEventType(key);
+            if (type == EventType::Unknown) continue;
+
+            EventConfig config;
+            int allowDuck, reqAudio;
+
+            // 格式: priority, ttl_ms, focus_window_ms, ducking_strength, allow_ducking, requires_audio
+            if (sscanf_s(value.c_str(), "%hhu, %u, %u, %f, %d, %d",
+                &config.priority, &config.ttlMs, &config.focusWindowMs,
+                &config.duckingStrength, &allowDuck, &reqAudio) == 6)
+            {
+                config.allowDucking = (allowDuck != 0);
+                config.requiresAudio = (reqAudio != 0);
+                eventConfigs[type] = config;
+
+                logger::info("[Haptics][Config] Event {}: pri={} ttl={}ms focus={}ms duck={:.2f} reqAudio={}",
+                    key, config.priority, config.ttlMs, config.focusWindowMs,
+                    config.duckingStrength, config.requiresAudio);
+            }
+        }
+    }
+    void HapticsConfig::LoadDuckingMatrix(const std::string& section,
+        const std::unordered_map<std::string, std::string>& values)
+    {
+        for (const auto& [key, value] : values) {
+            // 解析 "focus_type -> target_type"
+            size_t arrowPos = key.find("->");
+            if (arrowPos == std::string::npos) continue;
+
+            std::string focusStr = Trim(key.substr(0, arrowPos));
+            std::string targetStr = Trim(key.substr(arrowPos + 2));
+
+            EventType focusType = StringToEventType(focusStr);
+            EventType targetType = StringToEventType(targetStr);
+
+            if (focusType == EventType::Unknown || targetType == EventType::Unknown) continue;
+
+            float duckFactor = std::stof(value);
+
+            DuckingRule rule;
+            rule.focusType = focusType;
+            rule.targetType = targetType;
+            rule.duckFactor = std::clamp(duckFactor, 0.0f, 1.0f);
+
+            duckingRules.push_back(rule);
+
+            logger::info("[Haptics][Config] Ducking: {} -> {} = {:.2f}",
+                focusStr, targetStr, rule.duckFactor);
+        }
+    }
+    void HapticsConfig::LoadExtensionConfig(const std::string& section,
+        const std::unordered_map<std::string, std::string>& values)
+    {
+        if (values.count("enable_custom_events")) {
+            enableCustomEvents = (values.at("enable_custom_events") == "true");
+        }
+        if (values.count("max_custom_events")) {
+            maxCustomEvents = std::stoul(values.at("max_custom_events"));
+        }
+        if (values.count("custom_event_priority_base")) {
+            customEventPriorityBase = static_cast<std::uint8_t>(
+                std::stoul(values.at("custom_event_priority_base")));
+        }
+
+        logger::info("[Haptics][Config] Extension API: enabled={} maxCustom={} basePri={}",
+            enableCustomEvents, maxCustomEvents, customEventPriorityBase);
+    }
+    bool HapticsConfig::IsEventAllowed(EventType type) const
+    {
+        auto it = eventConfigs.find(type);
+        if (it == eventConfigs.end()) {
+            return true;  // 未配置的事件默认允许
+        }
+
+        const auto& config = it->second;
+
+        // 如果事件需要音频模式
+        if (config.requiresAudio) {
+            // 检查当前模式
+            if (hapticsMode != HapticsMode::AudioDriven) {
+                return allowSubtleEventsWithoutAudio;
+            }
+        }
+
+        return true;
+    }
+    const HapticsConfig::EventConfig* HapticsConfig::GetEventConfig(EventType type) const
+    {
+        auto it = eventConfigs.find(type);
+        return (it != eventConfigs.end()) ? &it->second : nullptr;
+    }
+    EventType HapticsConfig::StringToEventType(const std::string& str) const
+    {
+        static const std::unordered_map<std::string, EventType> map = {
+            {"hit_impact", EventType::HitImpact},
+            {"block", EventType::Block},
+            {"weapon_swing", EventType::WeaponSwing},
+            {"spell_impact", EventType::SpellImpact},
+            {"spell_cast", EventType::SpellCast},
+            {"land", EventType::Land},
+            {"jump", EventType::Jump},
+            {"footstep", EventType::Footstep},
+            {"bow_release", EventType::BowRelease},
+            {"shout", EventType::Shout}
+        };
+
+        auto it = map.find(str);
+        return (it != map.end()) ? it->second : EventType::Unknown;
+    }
+}
