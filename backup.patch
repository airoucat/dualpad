+		struct ScopedCOM
+		{
+			HRESULT hr{ E_FAIL };
+			bool needUninit{ false };
+
+			ScopedCOM()
+			{
+				hr = CoInitializeEx(nullptr, COINIT_MULTITHREADED);
+				if (SUCCEEDED(hr)) {
+					needUninit = true;
+				}
+				else if (hr == RPC_E_CHANGED_MODE) {
+					hr = S_OK;
+					needUninit = false;
+				}
+			}
+
+			~ScopedCOM()
+			{
+				if (needUninit) {
+					CoUninitialize();
+				}
+			}
+
+			bool ok() const { return SUCCEEDED(hr); }
+		};
+
+		std::string WideToUtf8(const wchar_t* ws)
+		{
+			if (!ws || !*ws) {
+				return {};
+			}
+
+			const int needed = WideCharToMultiByte(CP_UTF8, 0, ws, -1, nullptr, 0, nullptr, nullptr);
+			if (needed <= 1) {
+				return {};
+			}
+
+			std::string out(static_cast<size_t>(needed), '\0');
+			WideCharToMultiByte(CP_UTF8, 0, ws, -1, out.data(), needed, nullptr, nullptr);
+			out.pop_back();
+			return out;
+		}
+
+		bool IsExecutableAddress(void* p)
+		{
+			if (!p) {
+				return false;
+			}
+
+			MEMORY_BASIC_INFORMATION mbi{};
+			if (!VirtualQuery(p, &mbi, sizeof(mbi))) {
+				return false;
+			}
+
+			if (mbi.State != MEM_COMMIT) {
+				return false;
+			}
+
+			const DWORD prot = mbi.Protect & 0xFF;
+			return prot == PAGE_EXECUTE ||
+				prot == PAGE_EXECUTE_READ ||
+				prot == PAGE_EXECUTE_READWRITE ||
+				prot == PAGE_EXECUTE_WRITECOPY;
+		}
+
+		void ExtractAudioFeatures(
+			const BYTE* data,
+			UINT32 dataSize,
+			WORD channels,
+			WORD bitsPerSample,
+			float& outRMS,
+			float& outPeak)
+		{
+			outRMS = 0.0f;
+			outPeak = 0.0f;
+
+			if (!data || dataSize == 0 || channels == 0 || bitsPerSample == 0) {
+				return;
+			}
+
+			const UINT32 bytesPerSample = bitsPerSample / 8;
+			if (bytesPerSample == 0) {
+				return;
+			}
+
+			const UINT32 totalSamples = dataSize / (bytesPerSample * channels);
+			if (totalSamples == 0) {
+				return;
+			}
+
+			double sumSquares = 0.0;
+			float maxAbs = 0.0f;
+
+			if (bitsPerSample == 16) {
+				auto samples = reinterpret_cast<const int16_t*>(data);
+				const UINT32 sampleCount = totalSamples * channels;
+				for (UINT32 i = 0; i < sampleCount; ++i) {
+					const float n = samples[i] / 32768.0f;
+					sumSquares += n * n;
+					maxAbs = std::max(maxAbs, std::abs(n));
+				}
+			}
+			else if (bitsPerSample == 32) {
+				auto samples = reinterpret_cast<const float*>(data);
+				const UINT32 sampleCount = totalSamples * channels;
+				for (UINT32 i = 0; i < sampleCount; ++i) {
+					sumSquares += samples[i] * samples[i];
+					maxAbs = std::max(maxAbs, std::abs(samples[i]));
+				}
+			}
+			else {
+				return;
+			}
+
+			outRMS = static_cast<float>(std::sqrt(sumSquares / (totalSamples * channels)));
+			outPeak = maxAbs;
+		}
+
+		void STDMETHODCALLTYPE Hook_DestroyVoice(IXAudio2SourceVoice* self)
+		{
+			if (self) {
+				VoiceManager::GetSingleton().OnVoiceDestroyed(self);
+			}
+			if (g_origDestroyVoice) {
+				g_origDestroyVoice(self);
+			}
+		}
+
+		HRESULT Hook_SubmitSourceBuffer_Common(
+			SubmitSourceBuffer_t origFn,
+			IXAudio2SourceVoice* self,
+			const XAUDIO2_BUFFER* pBuffer,
+			const XAUDIO2_BUFFER_WMA* pBufferWMA)
+		{
+			const auto n = g_submitSourceBufferCalls.fetch_add(1, std::memory_order_relaxed) + 1;
+			if (n <= 20 || n % 100 == 0) {
+				logger::info("[Haptics][XAudio2Hook] SubmitSourceBuffer called #{} self={:p} bytes={}",
+					n, static_cast<void*>(self), pBuffer ? pBuffer->AudioBytes : 0u);
+			}
+
+			if (!origFn) {
+				logger::error("[Haptics][XAudio2Hook] original SubmitSourceBuffer is null");
+				return E_FAIL;
+			}
+
+			if (self && pBuffer && pBuffer->pAudioData && pBuffer->AudioBytes > 0) {
+				XAUDIO2_VOICE_DETAILS details{};
+				self->GetVoiceDetails(&details);
+
+				const WORD channels = static_cast<WORD>(details.InputChannels);
+				const DWORD sampleRate = static_cast<DWORD>(details.InputSampleRate);
+
+				constexpr WORD bitsPerSample = 16;
+
+				float rms = 0.0f;
+				float peak = 0.0f;
+				ExtractAudioFeatures(pBuffer->pAudioData, pBuffer->AudioBytes, channels, bitsPerSample, rms, peak);
+
+				if (rms > 0.001f || peak > 0.001f) {
+					AudioFeatureMsg msg{};
+
+					const auto tpNow = Now();
+					msg.qpcStart = ToQPC(tpNow);
+
+					const UINT32 bytesPerFrame = static_cast<UINT32>(channels) * 2u;
+					const UINT32 frameCount = bytesPerFrame ? (pBuffer->AudioBytes / bytesPerFrame) : 0u;
+					const std::uint64_t durUs =
+						(sampleRate > 0) ? (static_cast<std::uint64_t>(frameCount) * 1000000ull / sampleRate) : 0ull;
+
+					msg.qpcEnd = msg.qpcStart + durUs;
+					msg.voiceId = 0;
+					msg.sampleRate = sampleRate;
+					msg.channels = channels;
+
+					msg.rms = rms;
+					msg.peak = peak;
+					msg.bandLow = rms * 0.5f;
+					msg.bandMid = rms * 0.3f;
+					msg.bandHigh = rms * 0.2f;
+					msg.attack = peak;
+					msg.energyL = rms;
+					msg.energyR = rms;
+
+					VoiceManager::GetSingleton().PushAudioFeature(msg);
+				}
+			}
+
+			return origFn(self, pBuffer, pBufferWMA);
+		}
+
+		HRESULT STDMETHODCALLTYPE Hook_SubmitSourceBuffer_0(
+			IXAudio2SourceVoice* self,
+			const XAUDIO2_BUFFER* pBuffer,
+			const XAUDIO2_BUFFER_WMA* pBufferWMA)
+		{
+			g_submitSlot0Hits.fetch_add(1, std::memory_order_relaxed);
+			return Hook_SubmitSourceBuffer_Common(g_origSubmitSourceBuffer, self, pBuffer, pBufferWMA);
+		}
+
+		bool SelfTestSubmitCall(IXAudio2SourceVoice* voice)
+		{
+			if (!voice) {
+				return false;
+			}
+
+			const auto before = g_submitSlot0Hits.load(std::memory_order_relaxed);
+
+			static std::array<BYTE, 192> s_silence{};
+			XAUDIO2_BUFFER buf{};
+			buf.AudioBytes = static_cast<UINT32>(s_silence.size());
+			buf.pAudioData = s_silence.data();
+			buf.Flags = XAUDIO2_END_OF_STREAM;
+
+			const HRESULT hr = voice->SubmitSourceBuffer(&buf, nullptr);
+			if (FAILED(hr)) {
+				logger::warn("[Haptics][XAudio2Hook] SelfTest SubmitSourceBuffer failed: hr=0x{:08X}", (unsigned)hr);
+				return false;
+			}
+
+			voice->FlushSourceBuffers();
+
+			const auto after = g_submitSlot0Hits.load(std::memory_order_relaxed);
+			return after > before;
+		}
+
+		bool TryInstallSubmitHookWithSelfTest(IXAudio2SourceVoice* probeVoice, void** outTarget)
+		{
+			if (!probeVoice || !outTarget) {
+				return false;
+			}
+			*outTarget = nullptr;
+
+			void*** obj = reinterpret_cast<void***>(probeVoice);
+			if (!obj || !*obj) {
+				return false;
+			}
+			void** vtbl = *obj;
+
+			constexpr int kCandidates[] = { 21, 22, 20, 19, 23 };
+
+			for (int idx : kCandidates) {
+				void* target = vtbl[idx];
+
+				if (!IsExecutableAddress(target)) {
+					continue;
+				}
+
+				g_origSubmitSourceBuffer = nullptr;
+
+				const MH_STATUS c = MH_CreateHook(
+					target,
+					reinterpret_cast<LPVOID>(&Hook_SubmitSourceBuffer_0),
+					reinterpret_cast<LPVOID*>(&g_origSubmitSourceBuffer));
+
+				if (c != MH_OK && c != MH_ERROR_ALREADY_CREATED) {
+					continue;
+				}
+
+				const MH_STATUS e = MH_EnableHook(target);
+				if (e != MH_OK && e != MH_ERROR_ENABLED) {
+					MH_RemoveHook(target);
+					g_origSubmitSourceBuffer = nullptr;
+					continue;
+				}
+
+				if (SelfTestSubmitCall(probeVoice)) {
+					logger::info("[Haptics][XAudio2Hook] SubmitSourceBuffer index {} verified (slot=0)", idx);
+					*outTarget = target;
+					return true;
+				}
+
+				MH_DisableHook(target);
+				MH_RemoveHook(target);
+				g_origSubmitSourceBuffer = nullptr;
+			}
+
+			return false;
+		}
+
+		HRESULT STDMETHODCALLTYPE Hook_CreateSourceVoice(
+			IXAudio2* self,
+			IXAudio2SourceVoice** ppSourceVoice,
+			const WAVEFORMATEX* pSourceFormat,
+			UINT32 Flags,
+			float MaxFrequencyRatio,
+			IXAudio2VoiceCallback* pCallback,
+			const XAUDIO2_VOICE_SENDS* pSendList,
+			const XAUDIO2_EFFECT_CHAIN* pEffectChain)
+		{
+			const auto n = g_createSourceVoiceCalls.fetch_add(1, std::memory_order_relaxed) + 1;
+			if (n <= 10 || n % 50 == 0) {
+				logger::info("[Haptics][XAudio2Hook] CreateSourceVoice called #{} self={:p}", n, static_cast<void*>(self));
+			}
+
+			if (!g_origCreateSourceVoice) {
+				logger::error("[Haptics][XAudio2Hook] g_origCreateSourceVoice is null");
+				return E_FAIL;
+			}
+
+			const HRESULT hr = g_origCreateSourceVoice(
+				self, ppSourceVoice, pSourceFormat, Flags, MaxFrequencyRatio, pCallback, pSendList, pEffectChain);
+
+			if (SUCCEEDED(hr) && ppSourceVoice && *ppSourceVoice) {
+				const uint32_t sr = pSourceFormat ? pSourceFormat->nSamplesPerSec : 48000;
+				const uint16_t ch = pSourceFormat ? pSourceFormat->nChannels : 2;
+
+				VoiceManager::GetSingleton().OnVoiceCreated(*ppSourceVoice, sr, ch, false);
+
+				XAudio2Hook::GetSingleton().EnsureDestroyHookInstalled(*ppSourceVoice);
+				XAudio2Hook::GetSingleton().EnsureSubmitBufferHookInstalled(*ppSourceVoice);
+
+				if (n <= 5) {
+					logger::info("[Haptics][XAudio2Hook] SourceVoice created: {:p} sr={} ch={}",
+						static_cast<void*>(*ppSourceVoice), sr, ch);
+				}
+			}
+
+			return hr;
+		}
+
+		HRESULT WINAPI Hook_XAudio2Create(IXAudio2** ppXAudio2, UINT32 Flags, XAUDIO2_PROCESSOR XAudio2Processor)
+		{
+			const auto n = g_xaudio2CreateCalls.fetch_add(1, std::memory_order_relaxed) + 1;
+			if (n <= 5 || n % 50 == 0) {
+				logger::info("[Haptics][XAudio2Hook] XAudio2Create called #{} Flags={} Processor={}", n, Flags, XAudio2Processor);
+			}
+
+			if (!g_origXAudio2Create) {
+				logger::error("[Haptics][XAudio2Hook] g_origXAudio2Create is null");
+				return E_FAIL;
+			}
+
+			const HRESULT hr = g_origXAudio2Create(ppXAudio2, Flags, XAudio2Processor);
+
+			// 延迟探测：游戏第一次成功创建 IXAudio2 后，用它来装 CreateSourceVoice hook
+			if (SUCCEEDED(hr) && ppXAudio2 && *ppXAudio2 && n <= 3) {
+				XAudio2Hook::GetSingleton().TryInstallCreateSourceVoiceHookFromInstance(*ppXAudio2);
+			}
+
+			return hr;
+		}
+	}
+
+	const char* ToString(XAudio2Version v)
+	{
+		switch (v) {
+		case XAudio2Version::XAudio2_7: return "XAudio2.7";
+		case XAudio2Version::XAudio2_8: return "XAudio2.8";
+		case XAudio2Version::XAudio2_9: return "XAudio2.9";
+		default: return "Unknown";
+		}
+	}
+
+	XAudio2Hook& XAudio2Hook::GetSingleton()
+	{
+		static XAudio2Hook s;
+		return s;
+	}
+
+	bool XAudio2Hook::ResolveXAudio2Create()
+	{
+		if (_xaudio2CreateProc) {
+			return true;
+		}
+
+		auto tryResolveInModule = [&](HMODULE mod, const char* modTagUtf8) -> bool {
+			if (!mod) {
+				return false;
+			}
+
+			FARPROC proc = GetProcAddress(mod, "XAudio2Create");
+			if (!proc) {
+				proc = GetProcAddress(mod, MAKEINTRESOURCEA(3));
+			}
+			if (!proc) {
+				return false;
+			}
+
+			_xaudioModule = mod;
+			_xaudio2CreateProc = reinterpret_cast<void*>(proc);
+			_version = XAudio2Version::Unknown;
+
+			logger::info("[Haptics][XAudio2Hook] Resolved XAudio2Create from {} at {:p}",
+				modTagUtf8 ? modTagUtf8 : "(unknown)", _xaudio2CreateProc);
+			return true;
+			};
+
+		constexpr const wchar_t* kNames[] = {
+			L"xaudio2_9redist.dll",
+			L"xaudio2_9.dll",
+			L"xaudio2_8.dll",
+			L"xaudio2_7.dll",
+			L"FAudio.dll"
+		};
+
+		for (auto name : kNames) {
+			HMODULE mod = GetModuleHandleW(name);
+			if (!mod) {
+				continue;
+			}
+			const auto tag = WideToUtf8(name);
+			if (tryResolveInModule(mod, tag.c_str())) {
+				return true;
+			}
+		}
+
+		HMODULE mods[2048]{};
+		DWORD cbNeeded = 0;
+		if (EnumProcessModules(GetCurrentProcess(), mods, sizeof(mods), &cbNeeded)) {
+			const DWORD count = cbNeeded / sizeof(HMODULE);
+			for (DWORD i = 0; i < count; ++i) {
+				wchar_t pathW[MAX_PATH]{};
+				if (!GetModuleFileNameExW(GetCurrentProcess(), mods[i], pathW, MAX_PATH)) {
+					continue;
+				}
+
+				const auto path = WideToUtf8(pathW);
+				if (tryResolveInModule(mods[i], path.c_str())) {
+					return true;
+				}
+			}
+		}
+
+		logger::warn("[Haptics][XAudio2Hook] XAudio2Create not found (name+fullscan+ordinal)");
+		return false;
+	}
+
+	void XAudio2Hook::TryInstallCreateSourceVoiceHookFromInstance(IXAudio2* xa)
+	{
+		if (!xa) {
+			return;
+		}
+
+		if (_createSourceVoiceHooked.load(std::memory_order_acquire)) {
+			return;
+		}
+
+		void*** obj = reinterpret_cast<void***>(xa);
+		if (!obj || !*obj) {
+			return;
+		}
+
+		void** vtbl = *obj;
+
+		constexpr int kCandidates[] = { 5, 8, 6, 7 };
+		for (int idx : kCandidates) {
+			void* p = vtbl[idx];
+
+			if (!IsExecutableAddress(p)) {
+				continue;
+			}
+
+			const MH_STATUS c = MH_CreateHook(
+				p,
+				reinterpret_cast<LPVOID>(&Hook_CreateSourceVoice),
+				reinterpret_cast<LPVOID*>(&g_origCreateSourceVoice));
+
+			if (c == MH_OK || c == MH_ERROR_ALREADY_CREATED) {
+				const MH_STATUS e = MH_EnableHook(p);
+				if (e == MH_OK || e == MH_ERROR_ENABLED) {
+					_targetCreateSourceVoice = p;
+					_createSourceVoiceHooked.store(true, std::memory_order_release);
+					logger::info("[Haptics][XAudio2Hook] CreateSourceVoice hook installed (lazy): vtbl[{}]={:p}", idx, p);
+					return;
+				}
+			}
+		}
+	}
+
+	bool XAudio2Hook::ProbeCreateSourceVoiceTarget(void** outTarget)
+	{
+		// 不再使用（已改为延迟探测）
+		if (outTarget) {
+			*outTarget = nullptr;
+		}
+		return false;
+	}
+
+	bool XAudio2Hook::ProbeSubmitSourceBufferTargetFromVoice(IXAudio2SourceVoice* voice, void** outTarget)
+	{
+		if (!voice || !outTarget) {
+			return false;
+		}
+		*outTarget = nullptr;
+
+		void*** obj = reinterpret_cast<void***>(voice);
+		if (!obj || !*obj) {
+			return false;
+		}
+		void** vtbl = *obj;
+
+		constexpr int kCandidates[] = { 21, 22, 20, 19, 23 };
+		for (int idx : kCandidates) {
+			void* p = vtbl[idx];
+			if (IsExecutableAddress(p)) {
+				*outTarget = p;
+				return true;
+			}
+		}
+		return false;
+	}
+
+	bool XAudio2Hook::ProbeDestroyVoiceTargetFromVoice(IXAudio2SourceVoice* voice, void** outTarget)
+	{
+		if (!voice || !outTarget) {
+			return false;
+		}
+		*outTarget = nullptr;
+
+		void*** obj = reinterpret_cast<void***>(voice);
+		if (!obj || !*obj) {
+			return false;
+		}
+		void** vtbl = *obj;
+
+		constexpr int kCandidates[] = { 18, 17, 19, 20, 16 };
+		for (int idx : kCandidates) {
+			void* p = vtbl[idx];
+			if (IsExecutableAddress(p)) {
+				*outTarget = p;
+				return true;
+			}
+		}
+		return false;
+	}
+
+	bool XAudio2Hook::EnsureSubmitBufferHookInstalled(IXAudio2SourceVoice* voice)
+	{
+		std::scoped_lock lk(_lock);
+
+		if (!_installed.load(std::memory_order_acquire)) {
+			return false;
+		}
+
+		if (_submitBufferHooked.load(std::memory_order_acquire)) {
+			return true;
+		}
+
+		void* target = nullptr;
+		if (!TryInstallSubmitHookWithSelfTest(voice, &target) || !target) {
+			return false;
+		}
+
+		_targetSubmitSourceBuffer = target;
+		_submitBufferHooked.store(true, std::memory_order_release);
+		logger::info("[Haptics][XAudio2Hook] SubmitSourceBuffer hook installed: target={:p}", target);
+		return true;
+	}
+
+	bool XAudio2Hook::EnsureDestroyHookInstalled(IXAudio2SourceVoice* voice)
+	{
+		std::scoped_lock lk(_lock);
+
+		if (!_installed.load(std::memory_order_acquire)) {
+			return false;
+		}
+		if (_destroyHookInstalled.load(std::memory_order_acquire)) {
+			return true;
+		}
+
+		void* target = nullptr;
+		if (!ProbeDestroyVoiceTargetFromVoice(voice, &target) || !target) {
+			return false;
+		}
+
+		const MH_STATUS c = MH_CreateHook(
+			target,
+			reinterpret_cast<LPVOID>(&Hook_DestroyVoice),
+			reinterpret_cast<LPVOID*>(&g_origDestroyVoice));
+
+		if (c != MH_OK && c != MH_ERROR_ALREADY_CREATED) {
+			logger::error("[Haptics][XAudio2Hook] MH_CreateHook(DestroyVoice) failed: {}", static_cast<int>(c));
+			return false;
+		}
+
+		const MH_STATUS e = MH_EnableHook(target);
+		if (e != MH_OK && e != MH_ERROR_ENABLED) {
+			logger::error("[Haptics][XAudio2Hook] MH_EnableHook(DestroyVoice) failed: {}", static_cast<int>(e));
+			return false;
+		}
+
+		_targetDestroyVoice = target;
+		_destroyHookInstalled.store(true, std::memory_order_release);
+		logger::info("[Haptics][XAudio2Hook] DestroyVoice hook installed: target={:p}", target);
+		return true;
+	}
+
+	bool XAudio2Hook::Install()
+	{
+		std::scoped_lock lk(_lock);
+
+		if (_installed.load(std::memory_order_acquire)) {
+			logger::warn("[Haptics][XAudio2Hook] Already installed");
+			return true;
+		}
+
+		logger::info("[Haptics][XAudio2Hook] ========================================");
+		logger::info("[Haptics][XAudio2Hook] Installing XAudio2 hooks (lazy strategy)...");
+		logger::info("[Haptics][XAudio2Hook] ========================================");
+
+		const MH_STATUS init = MH_Initialize();
+		if (init != MH_OK && init != MH_ERROR_ALREADY_INITIALIZED) {
+			logger::error("[Haptics][XAudio2Hook] MH_Initialize failed: {}", static_cast<int>(init));
+			return false;
+		}
+
+		const bool resolvedCreate = ResolveXAudio2Create();
+		if (!resolvedCreate) {
+			logger::warn("[Haptics][XAudio2Hook] ResolveXAudio2Create failed");
+			return false;
+		}
+
+		// 只装 XAudio2Create hook，等游戏自己创建实例后再延迟探测
+		if (_xaudio2CreateProc) {
+			const MH_STATUS c = MH_CreateHook(
+				_xaudio2CreateProc,
+				reinterpret_cast<LPVOID>(&Hook_XAudio2Create),
+				reinterpret_cast<LPVOID*>(&g_origXAudio2Create));
+
+			if (c == MH_OK || c == MH_ERROR_ALREADY_CREATED) {
+				const MH_STATUS e = MH_EnableHook(_xaudio2CreateProc);
+				if (e == MH_OK || e == MH_ERROR_ENABLED) {
+					logger::info("[Haptics][XAudio2Hook] XAudio2Create hook installed: {:p}", _xaudio2CreateProc);
+					_installed.store(true, std::memory_order_release);
+					logger::info("[Haptics][XAudio2Hook] Install done (lazy mode, will hook CreateSourceVoice on first XAudio2Create)");
+					return true;
+				}
+			}
+		}
+
+		logger::warn("[Haptics][XAudio2Hook] Install failed: could not hook XAudio2Create");
+		return false;
+	}
+
+	void XAudio2Hook::Uninstall()
+	{
+		std::scoped_lock lk(_lock);
+		if (!_installed.exchange(false, std::memory_order_acq_rel)) {
+			return;
+		}
+		if (_targetSubmitSourceBuffer) {
+			MH_DisableHook(_targetSubmitSourceBuffer);
+			MH_RemoveHook(_targetSubmitSourceBuffer);
+		}
+		if (_targetDestroyVoice) {
+			MH_DisableHook(_targetDestroyVoice);
+			MH_RemoveHook(_targetDestroyVoice);
+		}
+		if (_targetCreateSourceVoice) {
+			MH_DisableHook(_targetCreateSourceVoice);
+			MH_RemoveHook(_targetCreateSourceVoice);
+		}
+		if (_xaudio2CreateProc) {
+			MH_DisableHook(_xaudio2CreateProc);
+			MH_RemoveHook(_xaudio2CreateProc);
+		}
+		g_origSubmitSourceBuffer = nullptr;
+		g_origDestroyVoice = nullptr;
+		g_origCreateSourceVoice = nullptr;
+		g_origXAudio2Create = nullptr;
+		_targetSubmitSourceBuffer = nullptr;
+		_targetDestroyVoice = nullptr;
+		_targetCreateSourceVoice = nullptr;
+		_submitBufferHooked.store(false, std::memory_order_release);
+		_destroyHookInstalled.store(false, std::memory_order_release);
+		_createSourceVoiceHooked.store(false, std::memory_order_release);
+		logger::info("[Haptics][XAudio2Hook] Uninstalled");
+		logger::info("[Haptics][XAudio2Hook] Calls: XAudio2Create={} CreateSourceVoice={} SubmitSourceBuffer={}",
+			g_xaudio2CreateCalls.load(std::memory_order_relaxed),
+			g_createSourceVoiceCalls.load(std::memory_order_relaxed),
+			g_submitSourceBufferCalls.load(std::memory_order_relaxed));
+	}
+}
